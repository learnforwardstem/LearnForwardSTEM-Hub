# LearnForwardSTEM - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ==========================================
# Firebase Configuration
# ==========================================
# Get these from Firebase Console > Project Settings > Web App
VITE_FIREBASE_API_KEY=AIza...your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456ghi789

# ==========================================
# Gmail Configuration (Optional)
# ==========================================
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification enabled on your Google Account
VITE_GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ==========================================
# Discord Configuration (Optional)
# ==========================================
# Create webhook in Discord Server Settings > Integrations > Webhooks
# This can also be configured in the app UI, no need to set here
# VITE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ==========================================
# Application Configuration
# ==========================================
# Admin credentials (for testing only - should use Firebase Auth in production)
VITE_ADMIN_EMAIL=LearnForwardSTEM@gmail.com
VITE_ADMIN_PASSWORD=Admin

# ==========================================
# Build Configuration
# ==========================================
# Keep these as defaults unless you have specific requirements
VITE_ENVIRONMENT=development
VITE_API_BASE_URL=http://localhost:5173
